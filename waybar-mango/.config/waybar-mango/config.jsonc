{
  "layer": "top",
  "position": "top",
  "height": 38,
  "modules-left": [
    "ext/workspaces",
    "wlr/window"
  ],
  "modules-center": [
    "mpris"
  ],
  "modules-right": [
    "tray",
    "custom/updates",
    "custom/vpn",
    "idle_inhibitor",
    "cpu",
    "memory",
    "temperature",
    "backlight",
    "pulseaudio",
    "network",
    "bluetooth",
    "battery",
    "power-profiles-daemon",
    "custom/theme",
    "clock"
  ],
  "ext/workspaces": {
    "format": "{name}",
    "on-click": "activate",
    "sort-by-id": true,
    "ignore-hidden": true
  },
  "wlr/window": {
    "format": "{}",
    "max-length": 50
  },
  "clock": {
    "format": "َ°¥” {:%H:%M}",
    "format-alt": "َ°ƒ­ {:%d/%m/%Y}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "on-click": "gnome-calendar"
  },
  "pulseaudio": {
    "format": "{icon} {volume}",
    "format-muted": "َ°‌ں",
    "format-icons": {
      "headphone": "َ°‹‹",
      "headset": "َ°‹ژ",
      "default": ["َ°•؟", "َ°–€", "َ°•¾"]
    },
    "scroll-step": 5,
    "on-click": "~/.config/waybar/scripts/volume-menu.sh",
    "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "tooltip-format": "{desc} آ· {volume}"
  },
  "backlight": {
    "format": "{icon} {percent}",
    "format-icons": ["َ°ƒ‍", "َ°ƒ‌", "َ°ƒں", "َ°ƒ "],
    "on-scroll-up": "brightnessctl set 5%+",
    "on-scroll-down": "brightnessctl set 5%-",
    "tooltip-format": "Brillo آ· {percent}"
  },
  "network": {
    "format-wifi": "  {essid}",
    "format-ethernet": "َ°ˆ€ {ifname}",
    "format-disconnected": "âڑ  Desconectado",
    "tooltip-format": "{ifname} via {gwaddr}",
    "on-click": "nm-connection-editor"
  },
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "",
      "performance": "",
      "balanced": "",
      "power-saver": ""
    }
  },
  "bluetooth": {
    "format": "",
    "format-disabled": "",
    "format-connected": " {num_connections}",
    "tooltip-format": "{device_alias}",
    "tooltip-format-connected": "<b>{device_alias}</b>\n{device_address}",
    "tooltip-format-enumerate-connected": "<b>{device_alias}</b>\n{device_address}",
    "on-click": "blueman-manager"
  },
  "battery": {
    "states": {
      "good": 80,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}",
    "format-alt": "{icon} {capacity}",
    "format-charging": "َ°‚„",
    "format-charging-alt": "َ°‚„ {capacity}",
    "format-plugged": "َ°ڑ¥",
    "format-plugged-alt": "َ°ڑ¥ {capacity}",
    "format-full": "َ°‚…",
    "format-full-alt": "َ°‚… {capacity}",
    "format-icons": ["َ°‚ژ", "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"],
    "tooltip-format": "{timeTo} آ· {capacity}%"
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "",
      "deactivated": ""
    },
    "tooltip": true
  },
  "mpris": {
    "format": "<span foreground='#ff0000'>َ°—ƒ</span> {title} - {artist}",
    "format-paused": "<span foreground='#e89f71'>َ°ڈ¤</span> {title} - {artist}",
    "format-stopped": "<span foreground='#c5c8c6'>َ°“¦</span> Detenido",
    "player-icons": {
      "default": "َ°‹¾",
      "youtube-music-bin": "َ°—ƒ"
    },
    "status-icons": {
      "playing": "َ°گٹ",
      "paused": "َ°ڈ¤"
    },
    "tooltip-format": "{player_name} | {album}",
    "max-length": 35,
    "truncation-symbol": "â€¦",
    "on-click": "playerctl play-pause",
    "on-scroll-up": "playerctl previous",
    "on-scroll-down": "playerctl next"
  },
  "cpu": {
    "interval": 3,
    "format": "َ°»  {usage}%",
    "max-length": 15,
    "tooltip": true,
    "tooltip-format": "CPU: {usage}%\nFreq: {avg_frequency}GHz"
  },
  "memory": {
    "interval": 5,
    "format": "َ°چ› {}%",
    "max-length": 15,
    "tooltip": true,
    "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G\nSwap: {swapUsed:0.1f}G / {swapTotal:0.1f}G"
  },
  "temperature": {
    "interval": 4,
    "critical-threshold": 80,
    "format": "{icon} {temperatureC}آ°",
    "format-critical": "{icon} {temperatureC}آ°",
    "format-icons": ["َ°œ—", "َ±ƒƒ", "َ°”ڈ", "َ±ƒ‚", "َ°¸پ"],
    "max-length": 15,
    "tooltip": true
  },
  "tray": {
    "icon-size": 16,
    "spacing": 8,
    "show-passive-items": false,
    "ignored-items": ["blueman", "blueman-tray", "blueman-applet"]
  },
  "custom/updates": {
    "format": "َ°®¯ {}",
    "interval": 300,
    "exec": "~/.config/waybar/scripts/check-updates.sh",
    "exec-if": "exit 0",
    "on-click": "kitty -e bash -c 'sudo pacman -Syu && pkill -RTMIN+8 waybar'",
    "signal": 8,
    "tooltip": true,
    "return-type": "json"
  },
  "custom/vpn": {
    "format": "{}",
    "interval": 5,
    "exec": "~/.config/waybar/scripts/vpn-status.sh",
    "return-type": "json",
    "tooltip": true
  },
  "custom/theme": {
    "format": "َ°ڈک",
    "exec": "cat ~/.config/current-theme 2>/dev/null || echo 'dracula'",
    "interval": "once",
    "signal": 8,
    "on-click": "~/.dotfiles/scripts/theme-switch.sh --menu",
    "tooltip": true,
    "tooltip-format": "Tema activo: {}"
  }
}
